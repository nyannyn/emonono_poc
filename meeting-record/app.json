{
  "expo": {
    "name": "Speech-to-Text：AI 語音轉錄",
    "slug": "meeting-record",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F3F1EC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ella.meetingrecord",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "用於錄製會議音訊以進行即時字幕",
        "ITSAppUsesNonExemptEncryption": false,
        "NSSpeechRecognitionUsageDescription": "用於將你的語音即時轉成文字（裝置端辨識，不離開手機）",
        "NSPhotoLibraryUsageDescription": "用於選取或附加圖片到會議記錄（本 App 不會主動讀取相簿）",
        "NSPhotoLibraryAddUsageDescription": "用於將會議相關圖片儲存到你的相簿",
        "UIBackgroundModes": ["audio"]
      },
      "privacyManifests": {
        "NSPrivacyAccessedAPITypes": [
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp",
            "NSPrivacyAccessedAPITypeReasons": ["C617.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults",
            "NSPrivacyAccessedAPITypeReasons": ["CA92.1"]
          },
          {
            "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace",
            "NSPrivacyAccessedAPITypeReasons": ["E174.1"]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DEC59A"
      },
      "package": "com.ella.meetingrecord",
      "permissions": [
        "RECORD_AUDIO",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      "expo-audio",
      "expo-asset",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "用於錄製會議音訊以進行即時字幕",
          "speechRecognitionPermission": "用於將你的語音即時轉成文字（裝置端辨識，不離開手機）"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "134946cd-addc-42ab-bdc4-ebb327f3af87"
      }
    },
    "owner": "nyannyn_expo"
  }
}
