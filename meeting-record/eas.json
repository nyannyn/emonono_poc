{
  "cli": {
    "version": ">= 14.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false,
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_BUILD": "1"
      },
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_BUILD": "1"
      },
      "ios": {
        "resourceClass": "m-medium",
        "image": "latest"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6784312935",
        "ascApiKeyPath": "./asc_api_key.p8",
        "ascApiKeyId": "K63J44R459",
        "ascApiKeyIssuerId": "a171e6de-120e-4750-9900-b8dc5eb89430",
        "appleTeamId": "24AD9R4PQ2"
      }
    }
  }
}
